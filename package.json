{
  "name": "monokai-focus",
  "displayName": "Monokai Focus",
  "description": "A semantics-driven theme that minimizes visual noise by using color and typography only where they meaningfully disambiguate code.",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.14.0"
  },
  "categories": [
    "Themes"
  ],
  "scripts": {
    "build": "node generator/color-theme.ts"
  },
  "type": "module",
  "contributes": {
    "themes": [
      {
        "label": "Monokai Focus",
        "uiTheme": "vs-dark",
        "path": "./themes/monokai-focus-color-theme.json"
      }
    ]
  },
  "devDependencies": {
    "@types/nearest-color": "^0.4.1",
    "@types/node": "^25.6.2",
    "color": "^5.0.3",
    "color-name-list": "^14.37.0",
    "nearest-color": "^0.4.4",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "repository": "github:5cover/monokai-focus"
}
