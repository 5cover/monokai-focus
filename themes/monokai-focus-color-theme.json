{
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "*.deprecated": {
      "fontStyle": "strikethrough"
    },
    "comment": "#FCB369",
    "decorator": "#DEBAD6",
    "class": "#DEBAD6",
    "enum": "#A8DB75",
    "interface": "#A8DB75",
    "keyword": "#F2958C",
    "macro": "#AA9CF2",
    "namespace": "#A8DB75",
    "number": "#A8DB75",
    "operator": "#88D0D8",
    "parameter": {
      "fontStyle": "italic"
    },
    "regexp": "#ECCF79",
    "string": "#ECCF79",
    "struct": "#A8DB75",
    "type": "#A8DB75",
    "typeParameter": {
      "fontStyle": "italic",
      "foreground": "#A8DB75"
    },
    "function": "#DEBAD6",
    "*.typeHint": "#A8DB75"
  },
  "tokenColors": [
    {
      "name": "abstraction",
      "scope": [
        "end",
        "entity.name.function",
        "entity.name.type.class",
        "keyword.control.require.js",
        "keyword.control.require.jsx",
        "keyword.control.require.ts",
        "keyword.control.require.tsx",
        "meta.decorator.other.readwrite meta.variable.other.readwrite",
        "meta.function.decorator.type meta.function.support.type.python",
        "parameters.begin",
        "punctuation.decorator",
        "punctuation.section.arguments",
        "support.class",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#DEBAD6"
      }
    },
    {
      "name": "comment",
      "scope": "comment",
      "settings": {
        "foreground": "#FCB369"
      }
    },
    {
      "name": "declaration",
      "scope": [
        "constant.language.import-export-all.js",
        "constant.language.import-export-all.jsx",
        "constant.language.import-export-all.ts",
        "constant.language.import-export-all.tsx",
        "end.template.definition",
        "entity.name.section",
        "entity.other.attribute-name.class",
        "export.control keyword.control.js",
        "export.control keyword.control.jsx",
        "export.control keyword.control.ts",
        "export.control keyword.control.tsx",
        "external.js",
        "external.jsx",
        "external.ts",
        "external.tsx",
        "import-equals.js",
        "import-equals.jsx",
        "import-equals.ts",
        "import-equals.tsx",
        "keyword.declaration",
        "keyword.import",
        "keyword.other.typedef",
        "keyword.type.new",
        "meta.import.js",
        "meta.import.jsx",
        "meta.import.ts",
        "meta.import.tsx",
        "meta.separator.markdown",
        "modifier",
        "pseudo-class",
        "punctuation.definition.list.begin.markdown",
        "punctuation.section.angle-brackets.begin",
        "storage.type"
      ],
      "settings": {
        "foreground": "#88D0D8"
      }
    },
    {
      "name": "declaration",
      "scope": "markup.heading",
      "settings": {
        "foreground": "#88D0D8"
      }
    },
    {
      "name": "declaration emphasis",
