      "settings": {
        "foreground": "#979795"
      }
    },
    {
      "name": "emphasis",
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "emphasis quote",
      "scope": [
        "markup.italic markup.quote",
        "markup.quote markup.italic"
