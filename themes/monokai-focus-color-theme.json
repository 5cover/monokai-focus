      "settings": {
        "foreground": "#88D0D8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "declaration.reset",
      "scope": [
        "storage.type.function.arrow.js",
        "storage.type.function.arrow.jsx",
        "storage.type.function.arrow.ts",
        "storage.type.function.arrow.tsx"
      ],
      "settings": {
        "foreground": "#F8F8F2"
      }
    },
    {
      "name": "deprecated",
      "scope": "invalid.deprecated",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "dim",
      "scope": [
