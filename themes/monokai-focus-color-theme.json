        "markup.heading markup.quote markup.italic markup.bold",
        "markup.italic markup.bold markup.heading markup.quote",
        "markup.italic markup.bold markup.quote markup.heading",
        "markup.italic markup.heading markup.bold markup.quote",
        "markup.italic markup.heading markup.quote markup.bold",
        "markup.italic markup.quote markup.bold markup.heading",
        "markup.italic markup.quote markup.heading markup.bold",
        "markup.quote markup.bold markup.heading markup.italic",
        "markup.quote markup.bold markup.italic markup.heading",
        "markup.quote markup.heading markup.bold markup.italic",
        "markup.quote markup.heading markup.italic markup.bold",
        "markup.quote markup.italic markup.bold markup.heading",
        "markup.quote markup.italic markup.heading markup.bold"
      ],
      "settings": {
        "foreground": "#88D0D8",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "declaration emphasis strong",
      "scope": [
        "markup.bold markup.heading markup.italic",
        "markup.bold markup.italic markup.heading",
        "markup.heading markup.bold markup.italic",
        "markup.heading markup.italic markup.bold",
        "markup.italic markup.bold markup.heading",
        "markup.italic markup.heading markup.bold"
      ],
      "settings": {
        "foreground": "#88D0D8",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "declaration quote",
      "scope": [
        "markup.heading markup.quote",
        "markup.quote markup.heading"
      ],
      "settings": {
        "foreground": "#88D0D8"
      }
    },
    {
      "name": "declaration quote strong",
      "scope": [
        "markup.bold markup.heading markup.quote",
        "markup.bold markup.quote markup.heading",
        "markup.heading markup.bold markup.quote",
        "markup.heading markup.quote markup.bold",
        "markup.quote markup.bold markup.heading",
        "markup.quote markup.heading markup.bold"
