      "settings": {
        "foreground": "#AA9CF2"
      }
    },
    {
      "name": "operation",
      "scope": [
        "keyword.as",
        "keyword.conditional",
        "keyword.control.switch",
        "keyword.elif",
        "keyword.fi",
        "keyword.if",
        "keyword.loop",
        "keyword.operator.as",
        "keyword.operator.expression",
        "keyword.operator.expression.typeof",
        "keyword.operator.in",
        "keyword.operator.infer",
        "keyword.operator.instanceof",
        "keyword.operator.is",
        "keyword.operator.keyof",
        "keyword.operator.logical.python",
        "keyword.operator.new",
        "keyword.operator.of",
        "keyword.operator.type.asserts",
        "keyword.operator.void",
        "keyword.other.new",
        "keyword.satisfies",
        "keyword.then",
        "keyword.trycatch"
      ],
      "settings": {
        "foreground": "#88D0D8"
      }
    },
    {
      "name": "parameter",
      "scope": "variable.parameter",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "quote",
      "scope": "markup.quote",
      "settings": {
        "foreground": "#C2C2BD"
      }
    },
    {
      "name": "quote strong",
      "scope": [
        "markup.bold markup.quote",
        "markup.quote markup.bold"
      ],
      "settings": {
        "foreground": "#C2C2BD",
        "fontStyle": "bold"
      }
    },
    {
      "name": "strong",
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "text",
      "scope": [
        "markup.inline.raw",
        "markup.raw",
        "string",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ECCF79"
      }
    },
    {
      "name": "text.reset",
      "scope": [
        "meta.object-literal.key meta.object-literal.string",
        "string meta.embedded",
        "string meta.template.expression",
        "string parameter-expansion",
        "string punctuation.definition.template-expression",
        "string punctuation.section.embedded",
        "string subshell",
        "string variable"
      ],
      "settings": {
        "foreground": "#F8F8F2"
      }
    },
    {
      "name": "type",
      "scope": [
        "end.template.call",
        "entity.name.type",
        "entity.other.inherited-class",
        "keyword.type",
        "meta.type.annotation.modifier meta.type.storage.modifier.js",
        "meta.type.annotation.modifier meta.type.storage.modifier.jsx",
        "meta.type.annotation.modifier meta.type.storage.modifier.ts",
        "meta.type.annotation.modifier meta.type.storage.modifier.tsx",
        "punctuation.definition.typeparameters",
        "punctuation.section.angle-brackets.begin",
        "storage.type.primitive",
        "struct",
        "support"
      ],
      "settings": {
        "foreground": "#A8DB75"
      }
    },
    {
      "name": "type.reset",
      "scope": [
        "entity.name.tag.yaml",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#F8F8F2"
      }
    }
