        "markup.heading markup.italic",
        "markup.italic markup.heading"
      ],
      "settings": {
        "foreground": "#88D0D8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "declaration emphasis quote",
      "scope": [
        "markup.heading markup.italic markup.quote",
        "markup.heading markup.quote markup.italic",
        "markup.italic markup.heading markup.quote",
        "markup.italic markup.quote markup.heading",
        "markup.quote markup.heading markup.italic",
        "markup.quote markup.italic markup.heading"
