        "markup.bold markup.italic markup.quote",
        "markup.bold markup.quote markup.italic",
        "markup.italic markup.bold markup.quote",
        "markup.italic markup.quote markup.bold",
        "markup.quote markup.bold markup.italic",
        "markup.quote markup.italic markup.bold"
      ],
      "settings": {
        "foreground": "#C2C2BD",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "emphasis strong",
      "scope": [
        "markup.bold markup.italic",
        "markup.italic markup.bold"
      ],
      "settings": {
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "illegal",
      "scope": "invalid.illegal",
      "settings": {
        "foreground": "#F53D3D",
        "fontStyle": "bold"
      }
    },
    {
      "name": "instruction",
      "scope": [
