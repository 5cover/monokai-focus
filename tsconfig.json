{
  "compilerOptions": {
    "module": "nodenext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "checkJs": false,
    "experimentalDecorators": false,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true,
    "types": [
      "node",
      "json-schema"
    ]
  },
  "include": [
    "scripts/**/*.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "demo",
    "node_modules",
    "**/node_modules/*"
  ]
}
