{
  "compilerOptions": {
    "module": "nodenext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "checkJs": false,
    "experimentalDecorators": false,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "types": [
      "node"
    ]
  },
  "exclude": [
    "node_modules",
    "**/node_modules/*"
  ]
}
